<Root xmlns="http://notenoughupdates.org/moulconfig">
    <Gui>
        <Column>
            <Meta afterClose="@afterClose"/>
            <Center>
                <Scale scale="2">
                    <Text text="Per Sea Creature Settings"/>
                </Scale>
            </Center>
            <Spacer height="5"/>
            <Center>
                <Row>
                    <Button onClick="@showLootshare">
                        <Text text="Lootshare Sphere Settings"/>
                    </Button>
                </Row>
            </Center>
            <Center>
                <Row>
                    <Button onClick="@showHealthDisp">
                        <Text text="Health Display Settings"/>
                    </Button>
                </Row>
            </Center>
            <Center>
                <Row>
                    <Button onClick="@showKillTime">
                        <Text text="Kill Time Settings"/>
                    </Button>
                </Row>
            </Center>
            <Center>
                <Row>
                    <Button onClick="@showHighlight">
                        <Text text="Mobs To Highlight"/>
                    </Button>
                </Row>
            </Center>
            <Center>
                <Button onClick="@showOtherNotify">
                    <Text text="Title When Seeing"/>
                </Button>
            </Center>
            <Spacer height="5"/>
            <Center>
                <Text text="On Hook Toggles"/>
            </Center>
            <Center>
                <Row>
                    <Button onClick="@showSelfNotify">
                        <Text text="Show Title"/>
                    </Button>
                    <Spacer width="10"/>
                    <Button onClick="@showShareParty">
                        <Text text="Share in Party"/>
                    </Button>
                </Row>
            </Center>
            <Spacer height = "5"/>
            <Center><Text text = "Cocoon Notification Toggles"/></Center>
            <Center>
                <Row>
                    <Button onClick="@showCocoonChatSettings">
                        <Text text="Send To Party Chat"/>
                    </Button>
                    <Spacer width = "10" />
                    <Button onClick="@showCocoonWarnSettings">
                        <Text text="Title To Self"/>
                    </Button>
                </Row>
            </Center>
        </Column>
    </Gui>
</Root>
